rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Username reservation — anyone authenticated can check availability,
    // only the owner can create/delete their reservation
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Email enumeration protection (hashed emails)
    // Anyone can verify if a specific hash exists (get), but no one can list them
    match /registered_emails/{hash} {
      allow get: if true;
      allow create: if request.auth != null;
    }

    // App config (OTA updates, etc) -> Anyone can read
    match /app_config/{document=**} {
      allow read: if true;
    }
  }
}
