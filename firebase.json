{
  "firestore": {
    "rules": "firestore.rules"
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "SecureVault",
        "supportEmail": "mohdjamal1110@gmail.com"
      }
    }
  },
  "hosting": {
    "public": "ota-updates",
    "ignore": ["firebase.json", "**/.*"],
    "headers": [
      {
        "source": "**/*.zip",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
          { "key": "Content-Type", "value": "application/zip" }
        ]
      }
    ]
  }
}